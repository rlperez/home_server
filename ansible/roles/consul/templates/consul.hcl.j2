datacenter = "homelab"
data_dir   = "/opt/consul"

server = true
bootstrap_expect = 1

addresses {
  http = "0.0.0.0"
}

bind_addr      = "127.0.0.1"
advertise_addr = "127.0.0.1"
client_addr    = "0.0.0.0"

ui_config {
  enabled = true
}

connect {
  enabled = true
}

encrypt = "{{ nomad_server.consul.nomad_token }}"
